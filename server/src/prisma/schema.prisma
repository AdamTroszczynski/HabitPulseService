generator client {
  provider = "prisma-client"
  output   = "../../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Lang {
  PL @map("pl")
}

enum DateFormat {
  DD_MM_YYYY @map("dd-mm-yyyy")
  MM_DD_YYYY @map("mm-dd-yyyy")
  YYYY_MM_DD @map("yyyy-mm-dd")
}

enum ReminderTaskStatus {
  PENDING
  SENT
  CANCELLED
  FAILED
}

model User {
  id           Int        @id @default(autoincrement())
  email        String     @unique @db.VarChar(255)
  passwordHash String?    @map("password_hash")
  name         String     @db.VarChar(40)
  secretBase32 String?    @map("secret_base32")
  totpEnabled  Boolean    @default(false) @map("totp-enabled")
  googleId     String?    @unique @map("google_id")
  githubId     String?    @unique @map("github_id")
  dateFormat   DateFormat @default(DD_MM_YYYY) @map("date_format")
  lang         Lang       @default(PL)
  habits       Habit[]
  audits       Audit[]
  isVerified   Boolean    @default(false) @map("is_verified")
  lastLogin    DateTime?  @map("last_login")
  createdAt    DateTime   @default(now()) @map("created_at")
  updatedAt    DateTime   @updatedAt @map("updated_at")

  @@map("users")
}

model Audit {
  id            Int      @id @default(autoincrement())
  correlationId String?  @map("correlation_id")
  userId        Int?     @map("user_id")
  user          User?    @relation(fields: [userId], references: [id])
  url           String
  method        String
  ipAddress     String?  @map("ip_address")
  userAgent     String?  @map("user_agent")
  statusCode    Int      @map("status_code")
  statusMessage String   @map("status_message")
  error         String?
  createdAt     DateTime @default(now()) @map("created_at")

  @@map("audits")
}

model Habit {
  id         Int        @id @default(autoincrement())
  userId     Int        @map("user_id")
  user       User       @relation(fields: [userId], references: [id])
  name       String     @db.VarChar(255)
  desc       String?
  color      String?
  icon       String?
  frequency  String[]   @default([])
  isArchived Boolean    @default(false) @map("is_archived")
  reminder   Reminder?
  trackings  Tracking[]
  createdAt  DateTime   @default(now()) @map("created_at")
  updatedAt  DateTime   @updatedAt @map("updated_at")

  @@map("habits")
}

model Reminder {
  id               Int            @id @default(autoincrement())
  habitId          Int            @unique @map("habit_id")
  habit            Habit          @relation(fields: [habitId], references: [id])
  isReminderActive Boolean        @default(false) @map("is_reminder_active")
  preferredTime    String         @default("12:00") @map("preferred_time")
  frequency        String[]       @default([])
  createdAt        DateTime       @default(now()) @map("created_at")
  updatedAt        DateTime       @updatedAt @map("updated_at")
  reminderTasks    ReminderTask[]

  @@map("reminders")
}

model ReminderTask {
  id           Int                @id @default(autoincrement())
  reminderId   Int                @map("reminder_id")
  reminder     Reminder           @relation(fields: [reminderId], references: [id])
  jobId        String?            @unique @map("job_id")
  scheduledFor DateTime           @map("scheduled_for")
  status       ReminderTaskStatus @default(PENDING)
  sentAt       DateTime?          @map("sent_at")
  cancelledAt  DateTime?          @map("cancelled_at")
  failReason   String?            @map("fail_reason")
  createdAt    DateTime           @default(now()) @map("created_at")
  updatedAt    DateTime           @updatedAt @map("updated_at")

  @@map("reminder_tasks")
}

model Tracking {
  id         Int      @id @default(autoincrement())
  habitId    Int      @map("habit_id")
  habit      Habit    @relation(fields: [habitId], references: [id])
  day        DateTime @db.Date
  isFinished Boolean  @default(false) @map("is_finished")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  @@unique([habitId, day])
  @@map("trackings")
}
