{
  "extends": "../tsconfig.base.json",
  "exclude": ["node_modules", "dist", "coverage", "tests", "src/generated", "generated"],
  "include": ["src", "../shared"],
  "compilerOptions": {
    "rootDir": "../",
    "outDir": "./dist",
    "paths": {
      "@/*": ["./server/src/*"],
      "@shared/*": ["./shared/*"],
      "@prisma/*": ["./server/generated/prisma/*"]
    }
  }
}
